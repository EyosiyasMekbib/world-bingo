# ============================================================
# World Bingo — Production Environment Variables
# ============================================================
# Single source of truth for docker-compose.yml (repo root).
#
# Dokploy: paste all of these into the "Environment Variables"
#          panel of your Compose service.
#
# Local prod test: cp .env.example .env  (repo root)
# ============================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local dev (no Docker): set DATABASE_URL directly.
# Docker: docker-compose.yml builds DATABASE_URL from POSTGRES_* vars below;
#         still set DATABASE_URL here so the API process can read it directly.
DATABASE_URL=postgresql://postgres:change-me-strong-password@localhost:5432/world_bingo
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/world_bingo_test?schema=public

# Docker Compose PostgreSQL service config (must match DATABASE_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=world_bingo

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Docker: "redis" matches the service name in docker-compose.yml
REDIS_URL=redis://localhost:6379

# ─── JWT — RS256 Key Pair ─────────────────────────────────────────────────────
# Use EITHER the raw (\n-escaped) OR the base64-encoded format — not both.
#
# Option A — raw keys (same format as local dev):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   Paste the PEM content with literal \n between lines (one long string).
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----\n"

# Option B — base64-encoded (safer for env panels that strip newlines):
#   base64 -w 0 private.pem   → JWT_PRIVATE_KEY_BASE64
#   base64 -w 0 public.pem    → JWT_PUBLIC_KEY_BASE64
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use * to allow all origins, or a comma-separated list to restrict
CORS_ORIGIN=*

# ─── Public API URL ───────────────────────────────────────────────────────────
# Used to build absolute URLs for uploaded files served by the API
API_BASE_URL=https://api.yourdomain.com

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local   # local | gcs

# Google Cloud Storage (only required when STORAGE_PROVIDER=gcs)
# GCS_BUCKET=world-bingo-receipts
# GCS_PROJECT_ID=your-gcp-project-id

# ─── Telegram Login Widget ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
NUXT_PUBLIC_TELEGRAM_BOT_NAME=
NUXT_PUBLIC_TELEGRAM_BOT_ID=

# ─── Nuxt Internal API URL ────────────────────────────────────────────────────
# SSR server → API calls inside Docker network. Keep as-is unless you rename
# the "api" service in docker-compose.yml.
NUXT_API_BASE_SERVER=http://api:8080

# ─── Third-Party Game Providers (GASea Seamless Wallet API v3.1.0) ───────────
# Request credentials from GASea Technical Support
GASEA_API_BASE_URL=""              # e.g. https://api.gasea.com/v3
GASEA_API_KEY=""                   # 64-char alphanumeric (X-API-Key header)
GASEA_API_SECRET=""                # 64-char alphanumeric (HMAC-SHA256 X-Signature)
GASEA_DEFAULT_CURRENCY=ETB
# Public URL of the player web app — used as lobbyUrl in game launch
WEB_BASE_URL=https://www.aradabingo.bet

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Comma-separated IPs to exempt from the 100 req/min rate limit.
# Use this to whitelist test runners or trusted server IPs.
# Example: RATE_LIMIT_WHITELIST=1.2.3.4,5.6.7.8
RATE_LIMIT_WHITELIST=

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-grafana-password

# ─── Observability ────────────────────────────────────────────────────────────
# Central shared stack (GlitchTip errors, Loki logs, Tempo traces, Alertmanager,
# Uptime Kuma) runs from docker-compose.observability.yml on the dokploy-network.
# Every integration below is OFF by default — leave a value empty/false and the
# feature stays inert; the app boots and runs normally with nothing configured.
# See docs/observability.md for the full runbook.

# --- Error tracking (Sentry SDK → self-hosted GlitchTip) ---
# Empty DSN → Sentry/GlitchTip reporting is completely inert (no-op).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=                       # optional: git sha / version tag

# --- Distributed tracing (OpenTelemetry → Tempo) ---
# OTEL_ENABLED=false → no auto-instrumentation is loaded at startup.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://wb-tempo:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=world-bingo-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# --- Log shipping (pino → Loki) ---
# Empty LOKI_URL → logs stay on stdout only (no shipping).
LOKI_URL=
LOKI_LABEL_APP=world-bingo-api

# --- Postgres exporter (Prometheus) ---
# DSN the postgres-exporter connects with. Empty → exporter has nothing to scrape.
# e.g. postgresql://user:pass@host:5432/db?sslmode=disable
POSTGRES_EXPORTER_DSN=

# ─── GlitchTip (self-hosted error tracking) ───────────────────────────────────
# Consumed by docker-compose.observability.yml only. Change the secrets below
# before bringing the central stack up.
GLITCHTIP_SECRET_KEY=change-me-glitchtip-secret-key
GLITCHTIP_DOMAIN=https://glitchtip.example.com
GLITCHTIP_POSTGRES_PASSWORD=change-me-glitchtip-pg
GLITCHTIP_EMAIL_URL=consolemail://
GLITCHTIP_DEFAULT_FROM_EMAIL=alerts@example.com
# Celery worker tuning (safe defaults; rarely need changing)
GLITCHTIP_CELERY_WORKER_AUTOSCALE=1,3
GLITCHTIP_CELERY_WORKER_MAX_TASKS_PER_CHILD=10000
