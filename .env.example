# ============================================================
# World Bingo Monorepo — Root Environment Variables
# ============================================================
# Each app also has its own .env.example in its directory:
#   apps/api/.env.example      — Fastify API server
#   apps/web/.env.example      — Player-facing Nuxt app
#   apps/admin/.env.example    — Admin dashboard Nuxt app
#
# For local development, copy this file:
#   cp .env.example .env
# ============================================================

# Shared across apps (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=world_bingo

REDIS_URL=redis://localhost:6379

# Convenience shortcuts used by Turborepo tasks
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/world_bingo"
