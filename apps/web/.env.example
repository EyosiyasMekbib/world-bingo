# ============================================================
# World Bingo Web App — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- API Connection ---
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_WS_URL=/

# --- App Config ---
# NUXT_PUBLIC_APP_NAME="World Bingo"

# --- Telegram Login ---
NUXT_PUBLIC_TELEGRAM_BOT_NAME=

# --- Observability (Sentry / GlitchTip) ---
# Leave NUXT_PUBLIC_SENTRY_DSN empty to disable error reporting entirely (no-op).
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=production
