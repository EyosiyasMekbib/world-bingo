# ============================================================
# World Bingo Admin App — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- API Connection ---
NUXT_PUBLIC_API_BASE=/api

# --- JWT (server-side only — for SSR token verification) ---
# Must match the JWT_SECRET in apps/api/.env
NUXT_JWT_SECRET="change-me-in-production-use-openssl-rand-hex-64"
