# ============================================================
# World Bingo Admin App — Environment Variables
# ============================================================
# For local development only. In Docker/Dokploy these are
# set via infrastructure/docker-compose.yml (see root .env.example).
# ============================================================

# --- API Connection (public, client-side) ---
NUXT_PUBLIC_API_BASE=http://localhost:8080

# --- API Connection (server-side SSR calls) ---
# In Docker this is set to http://api:8080 via NUXT_API_BASE_SERVER
NUXT_API_BASE_SERVER=http://localhost:8080

# --- Error reporting (Sentry/GlitchTip, public/client-bundled) ---
# Leave NUXT_PUBLIC_SENTRY_DSN empty to keep Sentry fully inert (default).
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=production
