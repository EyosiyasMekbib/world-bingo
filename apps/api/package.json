{
    "name": "@world-bingo/api",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "test": "DATABASE_URL='postgresql://postgres:postgres@localhost:5432/world_bingo_test?schema=public' vitest run",
        "test:coverage": "DATABASE_URL='postgresql://postgres:postgres@localhost:5432/world_bingo_test?schema=public' vitest run --coverage",
        "db:migrate": "prisma migrate dev",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@bull-board/api": "^6.19.0",
        "@bull-board/fastify": "^6.19.0",
        "@fastify/cors": "^10.0.0",
        "@fastify/formbody": "^8.0.2",
        "@fastify/helmet": "^12.0.0",
        "@fastify/jwt": "^9.0.0",
        "@fastify/multipart": "^9.0.0",
        "@fastify/rate-limit": "^10.0.0",
        "@fastify/static": "^9.0.0",
        "@fastify/swagger": "^9.0.0",
        "@fastify/swagger-ui": "^5.0.0",
        "@prisma/client": "^5.22.0",
        "@socket.io/redis-adapter": "^8.3.0",
        "@world-bingo/game-logic": "workspace:*",
        "@world-bingo/shared-types": "workspace:*",
        "bcryptjs": "^3.0.3",
        "bullmq": "^5.0.0",
        "dotenv": "^17.3.1",
        "fastify": "^5.2.0",
        "fastify-type-provider-zod": "^4.0.2",
        "ioredis": "^5.4.0",
        "jsonwebtoken": "^9.0.3",
        "pino": "^9.0.0",
        "redlock": "4.2.0",
        "socket.io": "^4.8.0",
        "zod": "^3.24.0",
        "zod-to-json-schema": "^3.25.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^3.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.0.0",
        "prisma": "^5.22.0",
        "tsx": "^4.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}