# ============================================================
# World Bingo API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Server ---
NODE_ENV=development          # development | production
PORT=8080
HOST=0.0.0.0

# --- Database (PostgreSQL) ---
# DATABASE_URL is defined in the root .env — do not set it here.
# Root .env is the single source of truth: cp ../../.env.example ../../.env

# --- Cache & Queues (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- Authentication (RS256) ---
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode (preserving newlines as \n) and store here:
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# --- File Storage ---
# For local dev use 'local'; for production use 'gcs'
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads           # Used when STORAGE_PROVIDER=local

# Google Cloud Storage (used when STORAGE_PROVIDER=gcs)
GCS_BUCKET_NAME="world-bingo-receipts"
GCS_PROJECT_ID="your-gcp-project-id"
GCS_KEY_FILE="./gcs-key.json"  # Path to service account JSON key

# --- Payment Gateways (Tier 6 — not needed for MVP) ---
# CHAPA_SECRET_KEY="CHASECK_TEST-..."
# CHAPA_WEBHOOK_SECRET="..."
# TELEBIRR_APP_ID="..."
# TELEBIRR_APP_KEY="..."

# --- Third-Party Game Providers (GASea Seamless Wallet API v3.1.0) ---
# Request credentials from GASea Technical Support
GASEA_API_BASE_URL=""              # e.g. https://api.gasea.com/v3
GASEA_API_KEY=""                   # 64-char alphanumeric (sent as X-API-Key header)
GASEA_API_SECRET=""                # 64-char alphanumeric (used for HMAC-SHA256 X-Signature)
GASEA_DEFAULT_CURRENCY="ETB"
# Public URL of this API — used in lobbyUrl for game launch and as callback base
WEB_BASE_URL="https://www.aradabingo.bet"

# --- Palace Casino (seamless wallet provider) ---
PALACE_API_BASE_URL=
PALACE_API_TOKEN=
PALACE_CALLBACK_TOKEN=
PALACE_CURRENCY=ETB

# ── Provider gateway hub ─────────────────────────────────────────────
# Multiple deployments can share ONE upstream provider account by routing
# all provider traffic through an elected "hub" deployment.
#   standalone (default) = single deployment, talks to providers directly (no change).
#   hub  = owns the provider token + the single callback URL; routes for spokes.
#   spoke = no provider credentials; forwards every provider call to the hub.
DEPLOYMENT_ROLE=standalone
# 3 lowercase-alphanumeric chars, unique per deployment. Required unless standalone.
DEPLOYMENT_CODE=
# Hub only: JSON array of the spokes this hub serves.
HUB_DEPLOYMENTS=                     # [{"code":"s01","baseUrl":"https://s01.example","secret":"<shared>"}]
# Spoke only: where the hub lives + the shared secret it authenticates with.
HUB_URL=
HUB_SHARED_SECRET=
# Optional: tighter timeout (ms) for the hub's forward leg to a spoke callback sink.
PALACE_SPOKE_TIMEOUT_MS=5000

# --- Telegram Login Widget ---
# Bot token from @BotFather — used only for hash verification, users never interact with the bot
TELEGRAM_BOT_TOKEN=

# --- Observability ---
# All integrations below are OFF by default: leave a value empty/false and the
# feature stays inert. The API boots and runs normally with nothing configured.
# Infra/exporter vars (GLITCHTIP_*, POSTGRES_EXPORTER_DSN, etc.) live in the root
# .env. See docs/observability.md for the full runbook.

# Error tracking (Sentry SDK → self-hosted GlitchTip).
# Empty DSN → reporting is a complete no-op.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=                       # optional: git sha / version tag

# Distributed tracing (OpenTelemetry auto-instrumentation → Tempo).
# OTEL_ENABLED=false → entrypoint runs node without --import (no instrumentation).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://wb-tempo:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=world-bingo-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Log shipping (pino → Loki). Empty LOKI_URL → logs stay on stdout only.
LOKI_URL=
LOKI_LABEL_APP=world-bingo-api
