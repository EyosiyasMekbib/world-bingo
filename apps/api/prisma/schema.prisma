generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid())
  serial           Int             @default(autoincrement()) @unique
  username         String?         @unique
  phone            String?         @unique
  passwordHash     String?
  telegramId       String?         @unique
  telegramUsername String?
  firstName        String?
  lastName         String?
  photoUrl         String?
  role             UserRole        @default(PLAYER)
  isActive         Boolean         @default(true)
  avatarUrl        String?
  referralCode     String?         @unique
  referredById     String?
  botTotalSpent    Decimal         @default(0) @db.Decimal(12, 2)
  wallet         Wallet?
  transactions   Transaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entries        GameEntry[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  referredBy     User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]          @relation("Referrals")
  referralRewards ReferralReward[]
  tournamentEntries TournamentEntry[]
  cashbackDisbursements CashbackDisbursement[]

  @@index([role])
  @@index([referralCode])
  @@map("users")
}

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @unique
  realBalance  Decimal  @default(0) @db.Decimal(20, 8)
  bonusBalance Decimal  @default(0) @db.Decimal(20, 8)
  currency     String   @default("ETB")
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Game {
  id             String       @id @default(uuid())
  title          String
  status         GameStatus   @default(WAITING)
  ticketPrice    Decimal      @db.Decimal(10, 2)
  maxPlayers     Int
  minPlayers     Int          @default(2)
  houseEdgePct   Decimal      @default(10) @db.Decimal(5, 2)
  pattern        PatternType
  calledBalls    Int[]
  entries        GameEntry[]
  createdAt      DateTime     @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  winnerId       String?
  templateId     String?
  template       GameTemplate? @relation(fields: [templateId], references: [id])

  @@index([status])
  @@index([status, createdAt])
  @@index([templateId, status])
  @@map("games")
}

// ─── Preconfigured Game Templates ──────────────────────────────────────────────
// Always-on game templates. The scheduler ensures at least one WAITING game
// exists per active template at all times. When minPlayers join, a 60-second
// countdown auto-starts the game — no manual admin start needed.
model GameTemplate {
  id             String      @id @default(uuid())
  title          String                              // e.g. "Quick 10 ETB"
  ticketPrice    Decimal     @db.Decimal(10, 2)
  maxPlayers     Int
  minPlayers     Int         @default(2)
  houseEdgePct   Decimal     @default(10) @db.Decimal(5, 2)
  pattern        PatternType
  active         Boolean     @default(true)          // toggle template on/off
  countdownSecs  Int         @default(60)            // seconds to wait after minPlayers join
  botEnabled     Boolean     @default(false)         // master on/off for bots on this template
  botCount       Int         @default(0)             // max number of bot players to inject per game
  botFillToMin   Boolean     @default(true)          // if true, bots fill to minPlayers (botCount is the ceiling)
  botMaxSpend    Decimal?    @db.Decimal(10, 2)      // per-template override for max ETB a single bot can spend
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  games          Game[]

  @@map("game_templates")
}

model Cartela {
  id      String      @id @default(uuid())
  serial  String      @unique
  grid    Json
  entries GameEntry[]

  @@map("cartelas")
}

model GameEntry {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  cartelaId String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  cartela   Cartela  @relation(fields: [cartelaId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([gameId, cartelaId])
  @@index([userId])
  @@index([gameId])
  @@index([gameId, userId])
  @@map("game_entries")
}

model Transaction {
  id                   String            @id @default(uuid())
  userId               String
  type                 TransactionType
  amount               Decimal           @db.Decimal(12, 2)
  status               PaymentStatus     @default(PENDING)
  referenceId          String?
  receiptUrl           String?
  note                 String?
  balanceBefore        Decimal?          @db.Decimal(12, 2)
  balanceAfter         Decimal?          @db.Decimal(12, 2)
  bonusBalanceBefore   Decimal?          @db.Decimal(12, 2)
  bonusBalanceAfter    Decimal?          @db.Decimal(12, 2)
  paymentTransactionId String?           @unique
  senderName           String?
  senderAccount        String?
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime          @default(now())

  @@index([userId])
  @@index([type, status])
  @@index([userId, type])
  @@index([createdAt])
  @@map("transactions")
}

enum UserRole {
  PLAYER
  ADMIN
  SUPER_ADMIN
}

enum GameStatus {
  WAITING
  STARTING
  LOCKING
  IN_PROGRESS
  PAYOUT
  REFUNDING
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  GAME_ENTRY
  PRIZE_WIN
  REFUND
  FIRST_DEPOSIT_BONUS
  CASHBACK_BONUS
  ADMIN_REAL_ADJUSTMENT
  ADMIN_BONUS_ADJUSTMENT
  TP_BET
  TP_WIN
  TP_ROLLBACK
  TP_ADJUSTMENT
}

enum PaymentStatus {
  PENDING
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PatternType {
  ANY_LINE
  DIAGONAL
  FULL_CARD
  X_PATTERN
  CORNERS
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  GAME_CANCELLED
  REFUND_PROCESSED
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  WITHDRAWAL_PROCESSED
  GAME_WON
  GAME_STARTING
  REFERRAL_BONUS
  TOURNAMENT_STARTING
  TOURNAMENT_WON
  TOURNAMENT_ELIMINATED
  CASHBACK_AWARDED
}

model ReferralReward {
  id          String   @id @default(uuid())
  referrerId  String
  refereeId   String   @unique   // one reward per referred user
  amount      Decimal  @db.Decimal(12, 2)
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  referrer    User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referral_rewards")
}

// ─── Progressive Jackpot (T59) ────────────────────────────────────────────────
model Jackpot {
  id          String        @id @default(uuid())
  amount      Decimal       @default(0) @db.Decimal(14, 2)
  lastWonAt   DateTime?
  lastWonBy   String?       // userId of last winner
  updatedAt   DateTime      @updatedAt
  wins        JackpotWin[]

  @@map("jackpot")
}

model JackpotWin {
  id        String   @id @default(uuid())
  jackpotId String
  userId    String
  gameId    String
  amount    Decimal  @db.Decimal(14, 2)
  ballCount Int      // number of balls called when won
  createdAt DateTime @default(now())
  jackpot   Jackpot  @relation(fields: [jackpotId], references: [id])

  @@index([userId])
  @@map("jackpot_wins")
}

// ─── Tournament Mode (T60) ─────────────────────────────────────────────────────
enum TournamentStatus {
  REGISTRATION  // open for sign-ups
  IN_PROGRESS   // rounds are running
  COMPLETED     // final winner determined
  CANCELLED
}

enum CashbackRefundType {
  PERCENTAGE
  FIXED
}

enum CashbackFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model Tournament {
  id              String           @id @default(uuid())
  title           String
  status          TournamentStatus @default(REGISTRATION)
  entryFee        Decimal          @db.Decimal(10, 2)
  maxPlayers      Int              @default(32)
  currentPlayers  Int              @default(0)
  prizePool       Decimal          @default(0) @db.Decimal(14, 2)
  houseEdgePct    Decimal          @default(10) @db.Decimal(5, 2)
  winnerId        String?
  rounds          Int              @default(1)  // total rounds played
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime         @default(now())
  entries         TournamentEntry[]
  tournamentGames TournamentGame[]

  @@index([status])
  @@index([status, scheduledAt])
  @@map("tournaments")
}

model TournamentEntry {
  id             String     @id @default(uuid())
  tournamentId   String
  userId         String
  round          Int        @default(1)   // last round they participated in
  eliminated     Boolean    @default(false)
  eliminatedAt   DateTime?
  score          Int        @default(0)   // # of games won in this tournament
  joinedAt       DateTime   @default(now())
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId, eliminated])
  @@map("tournament_entries")
}

model TournamentGame {
  id           String     @id @default(uuid())
  tournamentId String
  gameId       String     @unique  // each game belongs to at most one tournament
  round        Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, round])
  @@map("tournament_games")
}

// ─── Cashback Promotions ──────────────────────────────────────────────────────
model CashbackPromotion {
  id             String                 @id @default(uuid())
  name           String
  lossThreshold  Decimal                @db.Decimal(12, 2)   // net real-balance loss required to qualify
  refundType     CashbackRefundType                          // PERCENTAGE or FIXED
  refundValue    Decimal                @db.Decimal(10, 2)   // e.g. 10.00 = 10% OR 50.00 = 50 ETB flat
  frequency      CashbackFrequency                          // evaluation window: DAILY | WEEKLY | MONTHLY
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  disbursements  CashbackDisbursement[]

  @@map("cashback_promotions")
}

model CashbackDisbursement {
  id           String            @id @default(uuid())
  promotionId  String
  userId       String
  amount       Decimal           @db.Decimal(12, 2)
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime          @default(now())
  promotion    CashbackPromotion @relation(fields: [promotionId], references: [id])
  user         User              @relation(fields: [userId], references: [id])

  @@unique([promotionId, userId, periodStart])
  @@index([promotionId, periodStart])
  @@map("cashback_disbursements")
}

// ─── Site Settings / Feature Flags ──────────────────────────────────────────────
// A simple key-value store for admin-togglable features.
// Seeded with defaults; the admin panel can flip them on/off.
model SiteSetting {
  key       String   @id            // e.g. "feature_referrals", "feature_tournaments"
  value     String                  // "true" / "false" or any string value
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── House Wallet & Transactions ─────────────────────────────────────────────
// Singleton house wallet tracking all platform income/expenses.
model HouseWallet {
  id        String   @id @default("house")
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt DateTime @updatedAt

  @@map("house_wallet")
}

model HouseTransaction {
  id            String               @id @default(uuid())
  type          HouseTransactionType
  amount        Decimal              @db.Decimal(12, 2)
  description   String
  gameId        String?
  userId        String?
  balanceBefore Decimal              @db.Decimal(12, 2)
  balanceAfter  Decimal              @db.Decimal(12, 2)
  createdAt     DateTime             @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([userId])
  @@map("house_transactions")
}

enum HouseTransactionType {
  COMMISSION
  BOT_PRIZE_WIN
  REFUND_ISSUED
}

// ─── Third-Party Game Providers ───────────────────────────────────────────────

enum GameProviderStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ThirdPartyTxType {
  BET
  BET_RESULT
  BET_DEBIT
  BET_CREDIT
  ROLLBACK
  ADJUSTMENT
}

enum ThirdPartyTxStatus {
  COMPLETED
  ROLLED_BACK
  FAILED
}

// One row per aggregator (GASea is the first; more can be added).
// Credentials (apiKey, apiSecret) are stored in env vars only — not in this table.
model GameProvider {
  id         String             @id @default(uuid())
  code       String             @unique              // e.g. "gasea"
  name       String                                  // e.g. "GASea"
  status     GameProviderStatus @default(ACTIVE)
  apiBaseUrl String                                  // e.g. "https://api.gasea.com/v3"
  currency   String             @default("ETB")
  config     Json?                                   // provider-specific config blob
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  vendors    GameVendor[]
  games      ProviderGame[]

  @@map("game_providers")
}

// Game studios / sub-brands within a provider (e.g. Pragmatic Play, PG Soft).
model GameVendor {
  id           String       @id @default(uuid())
  providerId   String
  code         String                              // e.g. "PP"
  name         String                              // e.g. "Pragmatic Play"
  categoryCode String?                             // e.g. "SLOTS,LIVE"
  isActive     Boolean      @default(true)
  lastSyncedAt DateTime?
  provider     GameProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  games        ProviderGame[]

  @@unique([providerId, code])
  @@index([providerId, isActive])
  @@map("game_vendors")
}

// Individual games from a provider.
model ProviderGame {
  id             String       @id @default(uuid())
  providerId     String
  vendorId       String
  gameCode       String                              // e.g. "PP_1302" — unique within provider
  gameName       String
  categoryCode   String                              // e.g. "SLOTS", "LIVE", "TABLE"
  imageSquare    String?
  imageLandscape String?
  languageCodes  String[]                            // e.g. ["en", "am"]
  platformCodes  String[]                            // e.g. ["H5", "WEB"]
  currencyCodes  String[]                            // e.g. ["ETB", "USD"]
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  provider       GameProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vendor         GameVendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([providerId, gameCode])
  @@index([categoryCode])
  @@index([isActive, categoryCode])
  @@map("provider_games")
}

// Raw GASea transaction details + idempotency key.
// Every wallet callback creates one row here AND one row in the existing Transaction table.
model ThirdPartyTransaction {
  id                    String             @id @default(uuid())
  providerId            String
  userId                String
  transactionId         String                          // GASea's transactionId — idempotency key
  externalTransactionId String?                         // vendor-level transaction ID
  betId                 String?
  roundId               String?
  gameCode              String?
  type                  ThirdPartyTxType
  status                ThirdPartyTxStatus @default(COMPLETED)
  betAmount             Decimal?           @db.Decimal(20, 8)
  winAmount             Decimal?           @db.Decimal(20, 8)
  amount                Decimal            @db.Decimal(20, 8)  // net (positive = credit, negative = debit)
  balanceBefore         Decimal            @db.Decimal(20, 8)
  balanceAfter          Decimal            @db.Decimal(20, 8)
  rawRequest            Json?
  rawResponse           Json?
  createdAt             DateTime           @default(now())

  @@unique([providerId, transactionId])
  @@index([userId])
  @@index([roundId])
  @@index([createdAt])
  @@map("third_party_transactions")
}
