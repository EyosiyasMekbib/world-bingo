generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  phone          String          @unique
  passwordHash   String
  role           UserRole        @default(PLAYER)
  avatarUrl      String?
  referralCode   String?         @unique
  referredById   String?
  wallet         Wallet?
  transactions   Transaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entries        GameEntry[]
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  referredBy     User?           @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]          @relation("Referrals")
  referralRewards ReferralReward[]
  tournamentEntries TournamentEntry[]

  @@index([role])
  @@index([referralCode])
  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("ETB")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Game {
  id             String       @id @default(uuid())
  title          String
  status         GameStatus   @default(WAITING)
  ticketPrice    Decimal      @db.Decimal(10, 2)
  maxPlayers     Int
  minPlayers     Int          @default(2)
  houseEdgePct   Decimal      @default(10) @db.Decimal(5, 2)
  pattern        PatternType
  calledBalls    Int[]
  entries        GameEntry[]
  createdAt      DateTime     @default(now())
  startedAt      DateTime?
  endedAt        DateTime?
  winnerId       String?
  templateId     String?
  template       GameTemplate? @relation(fields: [templateId], references: [id])

  @@index([status])
  @@index([status, createdAt])
  @@index([templateId, status])
  @@map("games")
}

// ─── Preconfigured Game Templates ──────────────────────────────────────────────
// Always-on game templates. The scheduler ensures at least one WAITING game
// exists per active template at all times. When minPlayers join, a 60-second
// countdown auto-starts the game — no manual admin start needed.
model GameTemplate {
  id             String      @id @default(uuid())
  title          String                              // e.g. "Quick 10 ETB"
  ticketPrice    Decimal     @db.Decimal(10, 2)
  maxPlayers     Int
  minPlayers     Int         @default(2)
  houseEdgePct   Decimal     @default(10) @db.Decimal(5, 2)
  pattern        PatternType
  active         Boolean     @default(true)          // toggle template on/off
  countdownSecs  Int         @default(60)            // seconds to wait after minPlayers join
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  games          Game[]

  @@map("game_templates")
}

model Cartela {
  id      String      @id @default(uuid())
  serial  String      @unique
  grid    Json
  entries GameEntry[]

  @@map("cartelas")
}

model GameEntry {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  cartelaId String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  cartela   Cartela  @relation(fields: [cartelaId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([gameId, cartelaId])
  @@index([userId])
  @@index([gameId])
  @@index([gameId, userId])
  @@map("game_entries")
}

model Transaction {
  id                   String            @id @default(uuid())
  userId               String
  type                 TransactionType
  amount               Decimal           @db.Decimal(12, 2)
  status               PaymentStatus     @default(PENDING)
  referenceId          String?
  receiptUrl           String?
  note                 String?
  balanceBefore        Decimal?          @db.Decimal(12, 2)
  balanceAfter         Decimal?          @db.Decimal(12, 2)
  paymentTransactionId String?
  senderName           String?
  senderAccount        String?
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime          @default(now())

  @@index([userId])
  @@index([type, status])
  @@index([userId, type])
  @@index([createdAt])
  @@map("transactions")
}

enum UserRole {
  PLAYER
  ADMIN
  SUPER_ADMIN
}

enum GameStatus {
  WAITING
  STARTING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  GAME_ENTRY
  PRIZE_WIN
  REFUND
}

enum PaymentStatus {
  PENDING
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum PatternType {
  ANY_LINE
  DIAGONAL
  FULL_CARD
  X_PATTERN
  CORNERS
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  GAME_CANCELLED
  REFUND_PROCESSED
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  WITHDRAWAL_PROCESSED
  GAME_WON
  GAME_STARTING
  REFERRAL_BONUS
  TOURNAMENT_STARTING
  TOURNAMENT_WON
  TOURNAMENT_ELIMINATED
}

model ReferralReward {
  id          String   @id @default(uuid())
  referrerId  String
  refereeId   String   @unique   // one reward per referred user
  amount      Decimal  @db.Decimal(12, 2)
  paid        Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  referrer    User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referral_rewards")
}

// ─── Progressive Jackpot (T59) ────────────────────────────────────────────────
model Jackpot {
  id          String        @id @default(uuid())
  amount      Decimal       @default(0) @db.Decimal(14, 2)
  lastWonAt   DateTime?
  lastWonBy   String?       // userId of last winner
  updatedAt   DateTime      @updatedAt
  wins        JackpotWin[]

  @@map("jackpot")
}

model JackpotWin {
  id        String   @id @default(uuid())
  jackpotId String
  userId    String
  gameId    String
  amount    Decimal  @db.Decimal(14, 2)
  ballCount Int      // number of balls called when won
  createdAt DateTime @default(now())
  jackpot   Jackpot  @relation(fields: [jackpotId], references: [id])

  @@index([userId])
  @@map("jackpot_wins")
}

// ─── Tournament Mode (T60) ─────────────────────────────────────────────────────
enum TournamentStatus {
  REGISTRATION  // open for sign-ups
  IN_PROGRESS   // rounds are running
  COMPLETED     // final winner determined
  CANCELLED
}

model Tournament {
  id              String           @id @default(uuid())
  title           String
  status          TournamentStatus @default(REGISTRATION)
  entryFee        Decimal          @db.Decimal(10, 2)
  maxPlayers      Int              @default(32)
  currentPlayers  Int              @default(0)
  prizePool       Decimal          @default(0) @db.Decimal(14, 2)
  houseEdgePct    Decimal          @default(10) @db.Decimal(5, 2)
  winnerId        String?
  rounds          Int              @default(1)  // total rounds played
  scheduledAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime         @default(now())
  entries         TournamentEntry[]
  tournamentGames TournamentGame[]

  @@index([status])
  @@index([status, scheduledAt])
  @@map("tournaments")
}

model TournamentEntry {
  id             String     @id @default(uuid())
  tournamentId   String
  userId         String
  round          Int        @default(1)   // last round they participated in
  eliminated     Boolean    @default(false)
  eliminatedAt   DateTime?
  score          Int        @default(0)   // # of games won in this tournament
  joinedAt       DateTime   @default(now())
  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId, eliminated])
  @@map("tournament_entries")
}

model TournamentGame {
  id           String     @id @default(uuid())
  tournamentId String
  gameId       String     @unique  // each game belongs to at most one tournament
  round        Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, round])
  @@map("tournament_games")
}

// ─── Site Settings / Feature Flags ──────────────────────────────────────────────
// A simple key-value store for admin-togglable features.
// Seeded with defaults; the admin panel can flip them on/off.
model SiteSetting {
  key       String   @id            // e.g. "feature_referrals", "feature_tournaments"
  value     String                  // "true" / "false" or any string value
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
